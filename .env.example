# ── Gemini Vision API ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/price_pulse

# ── Telegram Alerts ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Scraper Config ────────────────────────────────────────────────────────────
SCRAPE_URL_BASE=https://lahore.punjab.gov.pk
SCRAPE_HOUR_PKT=7
SCRAPE_MINUTE_PKT=30

# ── Mode ──────────────────────────────────────────────────────────────────────
# true  = 1 category (vegetables), 1 image, 1 OCR call — for local testing
# false = all 4 categories — for production on Railway
TEST_MODE=true

# ── Environment ───────────────────────────────────────────────────────────────
ENV=development
