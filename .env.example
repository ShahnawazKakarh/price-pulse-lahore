# ── Gemini Vision API ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:port/dbname

# ── Telegram Alerts (optional) ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Scraper ───────────────────────────────────────────────────────────────────
SCRAPE_URL_BASE=https://lahore.punjab.gov.pk

# ── Mode ──────────────────────────────────────────────────────────────────────
# true  = scrape vegetables only (fast, minimal API calls — for development)
# false = all 4 categories (for production)
TEST_MODE=true

# ── Environment ───────────────────────────────────────────────────────────────
ENV=development
